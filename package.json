{
  "name": "brasa-govid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BRASA GovID system — sovereign citizen identity on Cloudflare Workers + D1.",
  "scripts": {
    "test": "node --test",
    "keygen": "node scripts/keygen.js",
    "db:init": "wrangler d1 execute brasa-citizens --file=./schema.sql",
    "db:init:local": "wrangler d1 execute brasa-citizens --local --file=./schema.sql",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
